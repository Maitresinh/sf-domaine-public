"""
9_cleanup.py
- Nettoyage HTML entities dans author, title, french_title, awards
- Diagnostic awards (écart award_count vs texte awards)
- Enrichissement Wikipedia : intro complète (pas juste summary)
"""
import sqlite3, html, re, requests, time

DB = '/app/data/sf_dp.sqlite'
conn = sqlite3.connect(DB)
cur  = conn.cursor()

# ─────────────────────────────────────────────────────────────
# 1. NETTOYAGE HTML ENTITIES
# ─────────────────────────────────────────────────────────────
print("=== 1. Nettoyage HTML entities ===")

for col in ['author', 'title', 'french_title', 'awards', 'synopsis']:
    cur.execute(f"SELECT title_id, {col} FROM works WHERE {col} LIKE '%&#%' OR {col} LIKE '%&amp;%' OR {col} LIKE '%&quot;%'")
    rows = cur.fetchall()
    print(f"  {col} : {len(rows)} lignes à nettoyer")
    for tid, val in rows:
        if val:
            cleaned = html.unescape(str(val))
            if cleaned != val:
                cur.execute(f"UPDATE works SET {col}=? WHERE title_id=?", (cleaned, tid))

conn.commit()
print("  ✅ HTML entities nettoyés\n")

# ─────────────────────────────────────────────────────────────
# 2. DIAGNOSTIC AWARDS
# ─────────────────────────────────────────────────────────────
print("=== 2. Diagnostic awards (DP sans VF) ===")

cur.execute("""
    SELECT COUNT(*) FROM works
    WHERE (dp_eu=1 OR dp_us=1) AND has_french_vf=0
    AND award_count > 0
""")
print(f"  award_count > 0       : {cur.fetchone()[0]}")

cur.execute("""
    SELECT COUNT(*) FROM works
    WHERE (dp_eu=1 OR dp_us=1) AND has_french_vf=0
    AND awards IS NOT NULL AND awards != ''
""")
print(f"  awards texte non vide : {cur.fetchone()[0]}")

cur.execute("""
    SELECT COUNT(*) FROM works
    WHERE (dp_eu=1 OR dp_us=1) AND has_french_vf=0
    AND award_count > 0
    AND (awards IS NULL OR awards = '')
""")
n_missing = cur.fetchone()[0]
print(f"  award_count > 0 MAIS awards vide : {n_missing}  ← bug à corriger")

# Échantillon des œuvres avec award_count mais sans texte
cur.execute("""
    SELECT title_id, title, author, award_count FROM works
    WHERE (dp_eu=1 OR dp_us=1) AND has_french_vf=0
    AND award_count > 0
    AND (awards IS NULL OR awards = '')
    LIMIT 10
""")
print("\n  Exemples manquants :")
missing_ids = []
for row in cur.fetchall():
    print(f"    [{row[0]}] {row[1]} — {row[2]} (award_count={row[3]})")
    missing_ids.append(row[0])
print()

# ─────────────────────────────────────────────────────────────
# 3. RECONSTRUIRE LE TEXTE AWARDS DEPUIS ISFDB (title_awards)
# ─────────────────────────────────────────────────────────────
print("=== 3. Reconstruction awards manquants ===")

ISFDB_DB = '/app/data/sf_dp.sqlite'  # si tu as un accès MariaDB, adapter ici
# Cette section nécessite un accès à MariaDB ISFDB
# Si disponible, décommenter et adapter :
"""
import mysql.connector
isf = mysql.connector.connect(host='mariadb-sfdb', port=3306,
                               user='root', password='root', database='isfdb')
ic = isf.cursor()

for tid in missing_ids:
    ic.execute('''
        SELECT at.award_type_name, ac.award_cat_name, ta.award_level,
               ta.award_year
        FROM title_awards ta
        JOIN award_cats ac ON ta.award_cat_id = ac.award_cat_id
        JOIN award_types at ON ac.award_cat_type_id = at.award_type_id
        WHERE ta.title_id = %s AND ta.award_level BETWEEN 1 AND 8
        ORDER BY ta.award_level, ta.award_year
    ''', (tid,))
    rows = ic.fetchall()
    if not rows: continue
    parts = []
    for atype, acat, level, ayear in rows:
        emoji = '🏆' if level == 1 else '🏅'
        parts.append(f"{emoji} {atype} – {acat} ({ayear})")
    awards_txt = ' | '.join(parts)
    cur.execute("UPDATE works SET awards=? WHERE title_id=?", (awards_txt, tid))

conn.commit()
isf.close()
print(f"  ✅ {len(missing_ids)} œuvres reconstruites")
"""
print("  (section MariaDB à décommenter si accès disponible)\n")

# ─────────────────────────────────────────────────────────────
# 4. ENRICHISSEMENT WIKIPEDIA — INTRO COMPLÈTE
#    Pour les œuvres DP sans VF avec wikipedia_url
# ─────────────────────────────────────────────────────────────
print("=== 4. Enrichissement Wikipedia intro complète ===")

cur.execute("""
    SELECT title_id, title, author, wikipedia_url, synopsis
    FROM works
    WHERE (dp_eu=1 OR dp_us=1)
    AND has_french_vf=0
    AND wikipedia_url IS NOT NULL AND wikipedia_url != ''
    AND (synopsis IS NULL OR length(synopsis) < 200)
    ORDER BY annualviews DESC NULLS LAST
    LIMIT 500
""")
rows = cur.fetchall()
print(f"  {len(rows)} œuvres avec URL Wikipedia et synopsis court/absent")

updated = 0
errors  = 0
for tid, title, author, wp_url, synopsis in rows:
    # Extraire le slug depuis l'URL
    slug = wp_url.rstrip('/').split('/')[-1]
    try:
        # API MediaWiki : intro complète (plus riche que REST summary)
        r = requests.get(
            'https://en.wikipedia.org/w/api.php',
            params={
                'action':   'query',
                'titles':   slug.replace('_', ' '),
                'prop':     'extracts',
                'exintro':  True,      # intro seulement (avant première section)
                'explaintext': True,   # texte brut, pas HTML
                'redirects': True,
                'format':   'json',
            },
            timeout=8
        )
        data  = r.json()
        pages = data.get('query', {}).get('pages', {})
        page  = next(iter(pages.values()))

        if page.get('pageid', -1) == -1:
            errors += 1
            continue

        extract = page.get('extract', '').strip()
        if extract and len(extract) > 150:
            # Nettoyer les sauts de ligne multiples
            extract = re.sub(r'\n{3,}', '\n\n', extract)
            cur.execute("""
                UPDATE works SET synopsis=?, synopsis_source='wikipedia_full'
                WHERE title_id=?
            """, (extract[:2000], tid))
            updated += 1
            if updated % 50 == 0:
                conn.commit()
                print(f"  ... {updated} mis à jour")

        time.sleep(0.3)  # respecter le rate limit Wikipedia

    except Exception as e:
        errors += 1
        if errors <= 5:
            print(f"  Erreur [{tid}] {title}: {e}")

conn.commit()
print(f"\n  ✅ {updated} synopsis enrichis, {errors} erreurs")

# ─────────────────────────────────────────────────────────────
# 5. STATS FINALES
# ─────────────────────────────────────────────────────────────
print("\n=== 5. Stats finales ===")
for label, sql in [
    ("Total DP sans VF",           "SELECT COUNT(*) FROM works WHERE (dp_eu=1 OR dp_us=1) AND has_french_vf=0"),
    ("Avec synopsis",              "SELECT COUNT(*) FROM works WHERE synopsis IS NOT NULL AND synopsis != ''"),
    ("Synopsis source isfdb",      "SELECT COUNT(*) FROM works WHERE synopsis_source='isfdb'"),
    ("Synopsis source wikipedia",  "SELECT COUNT(*) FROM works WHERE synopsis_source LIKE 'wikipedia%'"),
    ("Awards texte non vide",      "SELECT COUNT(*) FROM works WHERE awards IS NOT NULL AND awards != ''"),
    ("HTML entities restants",     "SELECT COUNT(*) FROM works WHERE author LIKE '%&#%' OR title LIKE '%&#%'"),
]:
    cur.execute(sql)
    print(f"  {label:40s}: {cur.fetchone()[0]}")

conn.close()
print("\n✅ 9_cleanup.py terminé")
